# The destination/output directory
public/

# Newer versions of hugo use this file
.hugo_build.lock

# Data that gets refreshed via external processes
data/**

# Cache of files generated by Hugo Pipes (--gc removes unused files)
resources/

# Stuff created by doing `npm install linkinator` in this directory (for running `make test` locally)
node_modules/
package-lock.json
package.json
